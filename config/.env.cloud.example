# Deepsee Cloud .env Template
# Copy to /opt/deepsee/.env on the cloud server.

APP_ENV=production
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///./data/app.db

# === Sync ===
SYNC_INTERVAL_SECONDS=0
EMAIL_SYNC_INTERVAL_SECONDS=0
NEWSNOW_REFRESH_INTERVAL_SECONDS=3600
NEWS_SNAPSHOT_INTERVAL_SECONDS=0
AGGREGATION_RETENTION_DAYS=90
AGGREGATION_RETENTION_INTERVAL_SECONDS=86400

# === AI (adjust max parallel for server specs) ===
AI_MAX_PARALLEL=2
SILICONFLOW_API_KEY=sk-your-key-here
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen3-30B-A3B
SILICONFLOW_TOOL_MODEL=Qwen/Qwen3-8B

# === WeChat Gateway (token/appId set via API, not here) ===
# The wechatapi.net base URL for iPad protocol
WECHATPAD_HTTP_BASE=http://api.wechatapi.net/finder/v2/api

# === Agent Bridge ===
# Set this to a strong random string before exposing beyond localhost
AGENT_API_TOKEN=<generate-a-strong-random-token>
AGENT_API_ALLOWLIST=/api/health,/api/ready,/api/messages,/api/email,/api/newsfeed,/api/ai,/api/send,/api/wechat-gateway,/api/config
AGENT_API_BLOCKLIST=/api/admin/cleanup,/api/admin/aggregation-retention/prune

# === API Auth (optional, for UI) ===
API_TOKEN=

# === Local integrations (optional, leave empty if not used) ===
CHATLOG_HTTP_BASE=
CHATLOG_DIR=
MEDIA_SERVER_BASE=
LANGBOT_ADAPTER_LOG_DIR=
